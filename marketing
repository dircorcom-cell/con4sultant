    <script>
        function calculateAll() {
            try {
                // 1. Core Data
                const rate = parseFloat(document.getElementById('rateSlider').value) || 13;
                document.getElementById('exchangeRateDisplay').innerText = `1 ريال = ${rate.toFixed(2)} جنيه`;

                // 2. Cairo OPEX (EGP)
                const cairoStaffIDs = ['s_gd', 's_vid', 's_web'];
                const cairoNumIDs = ['n_gd', 'n_vid', 'n_web'];
                let egpStaffTotal = 0;

                cairoStaffIDs.forEach((id, index) => {
                    const salInput = document.getElementById(id);
                    const numInput = document.getElementById(cairoNumIDs[index]);
                    const valDisplay = document.getElementById('v_' + id);
                    if (salInput && numInput && valDisplay) {
                        const salary = parseInt(salInput.value) || 0;
                        const count = parseInt(numInput.value) || 0;
                        valDisplay.innerText = salary.toLocaleString();
                        egpStaffTotal += (salary * count);
                    }
                });

                const rentEgInput = document.getElementById('rent_eg');
                const rentEgValue = rentEgInput ? (parseInt(rentEgInput.value) || 0) : 0;
                if (document.getElementById('v_rent_eg')) document.getElementById('v_rent_eg').innerText = rentEgValue.toLocaleString();

                const cairoBufferEgp = 10000; 
                const totalMonthlyCairoSAR = (egpStaffTotal + rentEgValue + cairoBufferEgp) / rate;

                // 3. Jeddah OPEX (SAR)
                const sMgmt = parseInt(document.getElementById('s_mgmt').value) || 0;
                const sSales = parseInt(document.getElementById('s_sales').value) || 0;
                const nSales = parseInt(document.getElementById('n_sales').value) || 0;
                const saas = parseInt(document.getElementById('saas').value) || 0;
                const promo = parseInt(document.getElementById('promo').value) || 0;

                document.getElementById('v_s_mgmt').innerText = sMgmt.toLocaleString();
                document.getElementById('v_s_sales').innerText = sSales.toLocaleString();
                document.getElementById('v_saas').innerText = saas.toLocaleString();
                document.getElementById('v_promo').innerText = promo.toLocaleString();

                const travelMonthly = 1000; 
                const auditorMonthly = 4000 / 12; 
                const totalMonthlyJeddahSAR = sMgmt + (sSales * nSales) + saas + promo + travelMonthly + auditorMonthly + 3500;

                // 4. CAPEX (SAR)
                const capBaseInput = document.getElementById('cap_base');
                const capBaseValue = capBaseInput ? (parseInt(capBaseInput.value) || 0) : 0;
                if (document.getElementById('v_cap_base')) document.getElementById('v_cap_base').innerText = capBaseValue.toLocaleString();
                
                const legalCairoSAR = 4000; 
                const totalCapex = legalCairoSAR + capBaseValue;

                // 5. REVENUES (SAR)
                const revItems = [1, 2, 5, 8];
                let monthlyRevTotal = 0;

                revItems.forEach(i => {
                    const priceSlider = document.getElementById('p' + i);
                    const qtyInput = document.getElementById('q' + i);
                    const priceDisplay = document.getElementById('v_p' + i);
                    if (priceSlider && qtyInput && priceDisplay) {
                        const price = parseInt(priceSlider.value) || 0;
                        const qty = parseInt(qtyInput.value) || 0;
                        priceDisplay.innerText = price.toLocaleString();
                        monthlyRevTotal += (price * qty);
                    }
                });

                document.getElementById('monthlyRev').innerText = Math.round(monthlyRevTotal).toLocaleString() + " ريال";
                
                // 6. TOTAL OPEX & PROFIT
                const totalMonthlyOpex = totalMonthlyCairoSAR + totalMonthlyJeddahSAR;
                const netProfit = monthlyRevTotal - totalMonthlyOpex;
                document.getElementById('monthlyNetProfit').innerText = Math.round(netProfit).toLocaleString();

                // 7. INVESTMENT ASK (Setup + 6 Months runway)
                const totalAsk = totalCapex + (totalMonthlyOpex * 6);
                document.getElementById('summaryAsk').innerText = Math.round(totalAsk).toLocaleString();
                document.getElementById('finalAskDisplay').innerText = Math.round(totalAsk).toLocaleString();

                // 8. INSTALLMENTS
                const d1 = totalCapex + (totalMonthlyOpex * 3);
                const d2 = totalMonthlyOpex * 2;
                const d3 = totalAsk - d1 - d2;

                document.getElementById('d1_val').innerText = Math.round(d1).toLocaleString() + " ريال";
                document.getElementById('d2_val').innerText = Math.round(d2).toLocaleString() + " ريال";
                document.getElementById('d3_val').innerText = Math.round(d3).toLocaleString() + " ريال";

                // 9. PROJECTIONS
                const y1Sales = monthlyRevTotal * 10; 
                const y1Opex = (totalMonthlyOpex * 12) + totalCapex;
                document.getElementById('y1_sales').innerText = Math.round(y1Sales).toLocaleString();
                document.getElementById('y1_opex').innerText = Math.round(y1Opex).toLocaleString();
                document.getElementById('y1_net').innerText = Math.round(y1Sales - y1Opex).toLocaleString();

                const y2Sales = y1Sales * 1.35 * 1.2; 
                const y2Opex = (totalMonthlyOpex * 12) * 1.1; 
                document.getElementById('y2_sales').innerText = Math.round(y2Sales).toLocaleString();
                document.getElementById('y2_opex').innerText = Math.round(y2Opex).toLocaleString();
                document.getElementById('y2_net').innerText = Math.round(y2Sales - y2Opex).toLocaleString();

                const y3Sales = y2Sales * 1.25;
                const y3Opex = y2Opex * 1.1;
                document.getElementById('y3_sales').innerText = Math.round(y3Sales).toLocaleString();
                document.getElementById('y3_opex').innerText = Math.round(y3Opex).toLocaleString();
                document.getElementById('y3_net').innerText = Math.round(y3Sales - y3Opex).toLocaleString();

                let rec = "";
                const ratio = monthlyRevTotal / totalMonthlyOpex;
                if (ratio < 1.1) rec = "المرحلة الحالية تركز على بناء الثبات؛ دعوتي لك هي الدخول كشريك لتأسيس الكيان وضمان الاستدامة.";
                else if (ratio < 1.8) rec = "هذا هو الوقت الذهبي لبدء الشراكة؛ التوازن بين التكاليف والإيرادات يسمح بنمو متسارع.";
                else rec = "نحن أمام محرك أرباح استثنائي. فارق الصرف يضمن لنا نمواً سريعاً وثباتاً في السوق السعودي.";
                document.getElementById('smartRec').innerText = rec;

            } catch (err) {
                console.error("Calculation Error:", err);
            }
        }

        window.onload = calculateAll;
    </script>
